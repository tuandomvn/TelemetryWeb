{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Telemetry": {
    "DataFolder": "App_Data",
    "DbFileNameTemplate": "telemetry-{yyyyMM}.litedb",
    "MaxEntries": 50000,
    "MaxMonthsToScan": 24
  },
  "AllowedHosts": "*"
}
