@page
@model IndexModel
@{
    ViewData["Title"] = "Telemetry Logs";
}


<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
    <div class="d-flex align-items-center gap-3">
        <div class="text-muted" id="lastUpdated">Last updated: -</div>
        <div class="form-check form-switch mb-0">
            <input class="form-check-input" type="checkbox" id="autoRefreshToggle" checked>
            <label class="form-check-label" for="autoRefreshToggle">Auto Refresh</label>
        </div>
    </div>
</div>

<div class="row g-3 align-items-end mb-3">
    <div class="col-md-2">
        <label for="appSelect" class="form-label">Filter by app</label>
        <select id="appSelect" class="form-select"></select>
    </div>
    <div class="col-md-2">
        <label for="dateSelect" class="form-label">Filter by date</label>
        <input id="dateSelect" type="date" class="form-control" />
    </div>
    <div class="col-md-2">
        <label for="levelSelect" class="form-label">Filter by level</label>
        <select id="levelSelect" class="form-select"></select>
    </div>
    <div class="col-md-4">
        <label for="searchBox" class="form-label">Search</label>
        <div class="d-flex gap-2">
            <input id="searchBox" type="text" class="form-control" placeholder="message" />
            <button id="searchBtn" class="btn btn-outline-primary" type="button">Search</button>
        </div>
    </div>

</div>

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css" />

@* <div class="d-flex justify-content-end mb-2">
    <span id="pageIndexLabel" class="text-muted small">Page 0 / 0</span>
</div> *@

<div class="table-responsive" style="max-height: 70vh;">
    <table id="logTable" class="table table-striped table-sm align-middle">
        <thead>
            <tr>
                <th style="width: 180px;">Timestamp</th>
                <th style="width: 160px;">App</th>
                <th style="width: 100px;">Level</th>
                <th>Message</th>
                <th style="width: 90px;">Action</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
</div>

<div class="d-flex justify-content-end mb-2">
    <span id="pageIndexLabel" class="text-muted small">Page 0 / 0</span>
</div>

@section Scripts {
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script>
    function escapeHtml(text) {
        if (text === null || text === undefined) return '';
        return String(text)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');
    }

    let logDataTable = null;

    function updatePageIndexLabel() {
        if (!logDataTable) return;
        const info = logDataTable.page.info();
        const currentPage = info.pages === 0 ? 0 : (info.page + 1);
        document.getElementById('pageIndexLabel').textContent = `Page ${currentPage} / ${info.pages}`;
    }

    function ensureDataTable() {
        if (logDataTable) return logDataTable;

        logDataTable = $('#logTable').DataTable({
            searching: false,
            lengthChange: false,
            pageLength: 200,
            order: [[0, 'desc']],
            pagingType: 'full_numbers',
            language: {
                emptyTable: 'No telemetry for selected filters.'
            },
            columns: [
                { data: 'timestamp' },
                { data: 'app' },
                { data: 'level' },
                { data: 'message' },
                { data: 'action', orderable: false, searchable: false }
            ]
        });

        logDataTable.on('draw', updatePageIndexLabel);
        updatePageIndexLabel();
        return logDataTable;
    }

    async function fetchApps() {
        const res = await fetch('/api/telemetry/apps');
        if (!res.ok) throw new Error(`Failed to load apps: ${res.status}`);

        const apps = await res.json();
        const select = document.getElementById('appSelect');
        select.innerHTML = '';

        const allOpt = document.createElement('option');
        allOpt.value = '';
        allOpt.textContent = 'All apps';
        select.appendChild(allOpt);

        apps.forEach(app => {
            const opt = document.createElement('option');
            opt.value = app;
            opt.textContent = app;
            select.appendChild(opt);
        });
    }

    async function fetchLevels() {
        const res = await fetch('/api/telemetry/levels');
        if (!res.ok) throw new Error(`Failed to load levels: ${res.status}`);

        const levels = await res.json();
        const select = document.getElementById('levelSelect');
        select.innerHTML = '';

        const allOpt = document.createElement('option');
        allOpt.value = '';
        allOpt.textContent = 'All levels';
        select.appendChild(allOpt);

        levels.forEach(level => {
            const opt = document.createElement('option');
            opt.value = level;
            opt.textContent = level;
            select.appendChild(opt);
        });
    }

    async function fetchLogs() {
        const select = document.getElementById('appSelect');
        const app = select?.value ?? '';
        const dateValue = document.getElementById('dateSelect')?.value ?? '';
        const q = document.getElementById('searchBox')?.value ?? '';
        const levelSelect = document.getElementById('levelSelect');
        const level = levelSelect?.value ?? '';

        let url = `/api/telemetry?app=${encodeURIComponent(app)}&limit=200`;
        if (dateValue) {
            url += `&date=${encodeURIComponent(dateValue)}`;
        }
        if (q.trim()) {
            url += `&q=${encodeURIComponent(q.trim())}`;
        }
        if (level.trim()) {
            url += `&level=${encodeURIComponent(level.trim())}`;
        }

        const res = await fetch(url);
        if (!res.ok) throw new Error(`Failed to load telemetry: ${res.status}`);

        const logs = await res.json();
        const rows = [];

        for (const entry of (Array.isArray(logs) ? logs : [])) {
            const ts = entry?.timestamp ? new Date(entry.timestamp) : null;
            const tsText = ts ? ts.toISOString().replace('T', ' ').replace('Z', '') : '';
            const xemHref = entry?.id
                ? `/Telemetry/Details?id=${encodeURIComponent(entry.id)}&timestamp=${encodeURIComponent(entry.timestamp ?? '')}`
                : null;

            rows.push({
                timestamp: escapeHtml(tsText),
                app: escapeHtml(entry.app),
                level: escapeHtml(entry.level ?? ''),
                message: escapeHtml(entry.message),
                action: xemHref ? `<a target="_blank" class="btn btn-outline-primary btn-sm" href="${xemHref}">Detail</a>` : ''
            });
        }

        const table = ensureDataTable();
        const previousPage = table.page();
        table.clear();
        table.rows.add(rows);
        table.draw(false);
        if (table.page.info().pages > previousPage) {
            table.page(previousPage).draw(false);
        }
        updatePageIndexLabel();

        document.getElementById('lastUpdated').textContent =
            `Last updated: ${new Date().toLocaleTimeString()}`;
    }

    (function init() {
        let autoRefreshInterval = null;
        const autoRefreshToggle = document.getElementById('autoRefreshToggle');

        const load = async () => {
            try {
                await fetchApps();
            } catch (e) {
                console.error(e);
            }

            try {
                await fetchLevels();
            } catch (e) {
                console.error(e);
            }

            try {
                await fetchLogs();
            } catch (e) {
                console.error(e);
            }

            if (autoRefreshToggle.checked) {
                autoRefreshInterval = setInterval(() => fetchLogs().catch(console.error), 5000);
            }
        };

        autoRefreshToggle.addEventListener('change', () => {
            if (autoRefreshToggle.checked) {
                fetchLogs().catch(console.error);
                autoRefreshInterval = setInterval(() => fetchLogs().catch(console.error), 5000);
            } else {
                if (autoRefreshInterval) {
                    clearInterval(autoRefreshInterval);
                    autoRefreshInterval = null;
                }
            }
        });

        document.getElementById('searchBtn').addEventListener('click', () => fetchLogs().catch(console.error));
        window.addEventListener('load', load);
    })();
</script>
<style>
    .dataTables_paginate .paginate_button {
    font-size: 0.85em;   /* Giảm kích thước chữ */
    padding: 2px 6px;    /* Giảm padding */
    min-width: 24px;     /* Giảm chiều rộng tối thiểu */
}
</style>
}
