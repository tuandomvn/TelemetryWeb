@page "/Stats/Today"
@model TelemetryWeb.Pages.Stats.TodayModel

@{
    ViewData["Title"] = "Today App Summary";
}


<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
    <div class="d-flex align-items-center gap-3">
        <div class="text-muted">
            Idle if no logs in the last <b>@Model.IdleMinutes</b> minutes
        </div>
        <div class="form-check form-switch mb-0">
            <input class="form-check-input" type="checkbox" id="autoRefreshToggle" checked>
            <label class="form-check-label" for="autoRefreshToggle">Auto Refresh</label>
        </div>
    </div>
</div>

<div class="alert alert-info">
    <div><b>Date:</b> @Model.Today</div>
    <div><b>Idle apps:</b> @Model.IdleCount</div>
</div>

<div class="table-responsive" style="max-height: 70vh;">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th style="width: 200px;">App/Service</th>
                <th style="width: 120px;">Logs Today</th>
                <th style="width: 240px;">Last Log</th>
                <th style="width: 120px;">Status</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr>
                    <td colspan="4" class="text-muted text-center">No telemetry data yet.</td>
                </tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    var rowClass = item.IsIdle ? "table-warning" : string.Empty;
                    <tr class="@rowClass">
                        <td>@item.App</td>
                        <td>@item.LogsToday</td>
                        <td>@(item.LastLogUtc.HasValue ? item.LastLogUtc.Value.ToString("u") : "-")</td>
                        <td>
                            @if (item.IsIdle)
                            {
                                <span class="badge bg-warning text-dark">Idle</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Active</span>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>
    (function() {
        let autoRefreshInterval = null;
        const autoRefreshToggle = document.getElementById('autoRefreshToggle');

        function setAutoRefresh() {
            if (autoRefreshToggle.checked) {
                autoRefreshInterval = setInterval(() => {
                    window.location.reload();
                }, 60*1000);
            } else {
                if (autoRefreshInterval) {
                    clearInterval(autoRefreshInterval);
                    autoRefreshInterval = null;
                }
            }
        }

        autoRefreshToggle.addEventListener('change', setAutoRefresh);
        setAutoRefresh();
    })();
</script>
}

